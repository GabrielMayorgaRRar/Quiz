<UserControl
    x:Class="Quiz.Features.Preguntas.PreguntaView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Quiz.Features.Preguntas"
    x:DataType="vm:PreguntaViewModel"
    mc:Ignorable="d">

    <DockPanel Margin="16">

        <!--  Formulario agregar  -->
        <StackPanel
            Margin="0,0,0,16"
            DockPanel.Dock="Top"
            Spacing="8">
            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Text="Preguntas" />
            <Grid ColumnDefinitions="*,200,Auto" RowDefinitions="Auto">
                <TextBox
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Text="{Binding Enunciado}"
                    Watermark="Texto de la pregunta" />
                <ComboBox
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    DisplayMemberBinding="{Binding Nombre}"
                    ItemsSource="{Binding Categorias}"
                    PlaceholderText="Categoría"
                    SelectedItem="{Binding CategoriaSeleccionada}" />
                <Button
                    Grid.Column="2"
                    Command="{Binding AgregarCommand}"
                    Content="Agregar" />
            </Grid>
        </StackPanel>

        <!--  Botón eliminar  -->
        <Button
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            Command="{Binding EliminarCommand}"
            Content="Eliminar seleccionada"
            DockPanel.Dock="Bottom" />

        <!--  Lista  -->
        <DataGrid
            AutoGenerateColumns="False"
            CanUserReorderColumns="True"
            CanUserResizeColumns="True"
            GridLinesVisibility="All"
            IsReadOnly="True"
            ItemsSource="{Binding Preguntas}"
            SelectedItem="{Binding PreguntaSeleccionada}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding Id}"
                    Header="Id" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Enunciado}"
                    Header="Pregunta" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding CategoriaId}"
                    Header="Categoría" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>
