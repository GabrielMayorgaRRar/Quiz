<UserControl
    x:Class="Quiz.Views.HomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="768"
    d:DesignWidth="1024"
    Background="#FAFAF9"
    FontFamily="Inter, Roboto, sans-serif"
    mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="TextBlock.serif">
            <Setter Property="FontFamily" Value="Georgia, Times New Roman, serif" />
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Courier New, monospace" />
        </Style>


        <Style Selector="Border.categoryCard">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D6D3D1" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.categoryCard:pointerover TextBlock.cardTitle">
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>

        <Style Selector="Border.history:pointerover">
            <Setter Property="Background" Value="#1AE07A5F" />
            <Setter Property="BorderBrush" Value="#E07A5F" />
        </Style>
        <Style Selector="Border.science:pointerover">
            <Setter Property="Background" Value="#1ABC4749" />
            <Setter Property="BorderBrush" Value="#BC4749" />
        </Style>
        <Style Selector="Border.music:pointerover">
            <Setter Property="Background" Value="#1AF2CC8F" />
            <Setter Property="BorderBrush" Value="#F2CC8F" />
        </Style>
        <Style Selector="Border.sports:pointerover">
            <Setter Property="Background" Value="#1AD4A373" />
            <Setter Property="BorderBrush" Value="#D4A373" />
        </Style>
        <Style Selector="Border.art:pointerover">
            <Setter Property="Background" Value="#1AE65C00" />
            <Setter Property="BorderBrush" Value="#E65C00" />
        </Style>

        <Style Selector="Border.divider">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="#E7E5E4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *, Auto">

        <Border
            Grid.Row="0"
            BorderBrush="#E7E5E4"
            BorderThickness="0,0,0,1">
            <Grid
                Margin="32,24"
                VerticalAlignment="Center"
                ColumnDefinitions="Auto,*,Auto">

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="16">
                    <Path
                        Width="28"
                        Height="28"
                        Data="M18 4H6C4.89543 4 4 4.89543 4 6V18C4 19.1046 4.89543 20 6 20H18C19.1046 20 20 19.1046 20 18V6C20 4.89543 19.1046 4 18 4Z M10.5 15.5L6.5 11.5L7.91 10.09L10.5 12.67L16.09 7.09L17.5 8.5L10.5 15.5Z"
                        Fill="#E07A5F"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Classes="serif"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#433829"
                        LetterSpacing="1"
                        Text="QUIZ MASTER" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="40">
                    <TextBlock
                        Cursor="Hand"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#433829"
                        Text="Play"
                        TextDecorations="Underline" />
                    <TextBlock
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="#78716C"
                        Text="Leaderboard" />
                    <TextBlock
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="#78716C"
                        Text="Collections" />
                </StackPanel>

                <Border
                    Grid.Column="2"
                    Padding="16,8"
                    BorderBrush="#D6D3D1"
                    BorderThickness="1"
                    CornerRadius="20"
                    Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Medium"
                            Foreground="#433829"
                            Text="Profile" />
                        <Path
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                            Fill="#A8A29E"
                            Stretch="Uniform" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid
                MaxWidth="1100"
                Margin="40,56,40,40"
                HorizontalAlignment="Center"
                RowDefinitions="Auto,*">

                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,64"
                    ColumnDefinitions="2*, 1*">
                    <StackPanel Grid.Column="0" Spacing="24">
                        <TextBlock
                            Classes="mono"
                            FontSize="12"
                            Foreground="#A8A29E"
                            LetterSpacing="2"
                            Text="Issue No. 42" />
                        <TextBlock
                            Classes="serif"
                            FontSize="64"
                            FontWeight="Normal"
                            Foreground="#433829"
                            LineHeight="72"
                            Text="Select Your Subject"
                            TextWrapping="Wrap" />
                        <TextBlock
                            MaxWidth="500"
                            FontSize="18"
                            Foreground="#78716C"
                            LineHeight="28"
                            Text="Test your knowledge across carefully curated categories. Challenge the community records and elevate your status in the archives."
                            TextWrapping="Wrap" />

                        <Button
                            Margin="0,16,0,0"
                            Padding="32,16"
                            HorizontalAlignment="Left"
                            Background="#E07A5F"
                            CornerRadius="0"
                            Foreground="#FAFAF9">
                            <TextBlock
                                Classes="mono"
                                FontSize="13"
                                FontWeight="SemiBold"
                                LetterSpacing="1"
                                Text="BEGIN ASSESMENT" />
                        </Button>
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Padding="32"
                        VerticalAlignment="Top"
                        BorderBrush="#D6D3D1"
                        BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Classes="mono"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="#E07A5F"
                                LetterSpacing="1"
                                Text="TODAY'S FOCUS" />
                            <TextBlock
                                Classes="serif"
                                FontSize="32"
                                Foreground="#433829"
                                Text="History" />
                            <TextBlock
                                FontSize="14"
                                Foreground="#78716C"
                                LineHeight="22"
                                Text="An exploration of classical antiquity and modern revolutions."
                                TextWrapping="Wrap" />
                            <Border Margin="0,8" Classes="divider" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="12"
                                    Foreground="#A8A29E"
                                    Text="Completion Rate" />
                                <TextBlock
                                    Grid.Column="1"
                                    Classes="mono"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#433829"
                                    Text="24%" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" RowDefinitions="Auto,*">
                    <Grid
                        Grid.Row="0"
                        Margin="0,0,0,24"
                        ColumnDefinitions="Auto,*">
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            Classes="serif"
                            FontSize="24"
                            Foreground="#433829"
                            Text="Archival Categories" />
                        <Border
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Classes="divider" />
                    </Grid>

                    <UniformGrid
                        Grid.Row="1"
                        Margin="-8,0"
                        Columns="5">

                        <Border Margin="8,0" Classes="categoryCard history">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Classes="mono"
                                    FontSize="24"
                                    FontWeight="Light"
                                    Foreground="#D6D3D1"
                                    Text="01" />
                                <StackPanel Grid.Row="1" Margin="0,32,0,32">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Classes="cardTitle serif"
                                        FontSize="20"
                                        Foreground="#433829"
                                        Text="History" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#78716C"
                                        LineHeight="20"
                                        Text="Chronicles of the past, empires, and eras."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="2"
                                    Classes="mono"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#E07A5F"
                                    LetterSpacing="1"
                                    Text="EXPLORE →" />
                            </Grid>
                        </Border>

                        <Border Margin="8,0" Classes="categoryCard science">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Classes="mono"
                                    FontSize="24"
                                    FontWeight="Light"
                                    Foreground="#D6D3D1"
                                    Text="02" />
                                <StackPanel Grid.Row="1" Margin="0,32,0,32">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Classes="cardTitle serif"
                                        FontSize="20"
                                        Foreground="#433829"
                                        Text="Science" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#78716C"
                                        LineHeight="20"
                                        Text="The mechanics of reality, from atoms to stars."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="2"
                                    Classes="mono"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#BC4749"
                                    LetterSpacing="1"
                                    Text="EXPLORE →" />
                            </Grid>
                        </Border>

                        <Border Margin="8,0" Classes="categoryCard music">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Classes="mono"
                                    FontSize="24"
                                    FontWeight="Light"
                                    Foreground="#D6D3D1"
                                    Text="03" />
                                <StackPanel Grid.Row="1" Margin="0,32,0,32">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Classes="cardTitle serif"
                                        FontSize="20"
                                        Foreground="#433829"
                                        Text="Music" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#78716C"
                                        LineHeight="20"
                                        Text="Harmonic theory, legendary composers and bands."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="2"
                                    Classes="mono"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#F2CC8F"
                                    LetterSpacing="1"
                                    Text="EXPLORE →" />
                            </Grid>
                        </Border>

                        <Border Margin="8,0" Classes="categoryCard sports">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Classes="mono"
                                    FontSize="24"
                                    FontWeight="Light"
                                    Foreground="#D6D3D1"
                                    Text="04" />
                                <StackPanel Grid.Row="1" Margin="0,32,0,32">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Classes="cardTitle serif"
                                        FontSize="20"
                                        Foreground="#433829"
                                        Text="Sports" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#78716C"
                                        LineHeight="20"
                                        Text="Athletic history, rules, and legendary events."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="2"
                                    Classes="mono"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#D4A373"
                                    LetterSpacing="1"
                                    Text="EXPLORE →" />
                            </Grid>
                        </Border>

                        <Border Margin="8,0" Classes="categoryCard art">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Classes="mono"
                                    FontSize="24"
                                    FontWeight="Light"
                                    Foreground="#D6D3D1"
                                    Text="05" />
                                <StackPanel Grid.Row="1" Margin="0,32,0,32">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Classes="cardTitle serif"
                                        FontSize="20"
                                        Foreground="#433829"
                                        Text="Art" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#78716C"
                                        LineHeight="20"
                                        Text="Visual aesthetics, painters, and art movements."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="2"
                                    Classes="mono"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="#E65C00"
                                    LetterSpacing="1"
                                    Text="EXPLORE →" />
                            </Grid>
                        </Border>

                    </UniformGrid>
                </Grid>

            </Grid>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Padding="40,24"
            Background="#F5F5F4"
            BorderBrush="#E7E5E4"
            BorderThickness="0,1,0,0">
            <Grid
                MaxWidth="1100"
                HorizontalAlignment="Center"
                ColumnDefinitions="*,*,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock
                        FontSize="12"
                        Foreground="#78716C"
                        Text="Current Ranking" />
                    <TextBlock
                        Classes="mono"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#433829"
                        Text="#2405" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Spacing="4">
                    <TextBlock
                        FontSize="12"
                        Foreground="#78716C"
                        Text="Completed Modules" />
                    <TextBlock
                        Classes="mono"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#433829"
                        Text="142" />
                </StackPanel>
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Spacing="4">
                    <TextBlock
                        FontSize="12"
                        Foreground="#78716C"
                        Text="Average Score" />
                    <TextBlock
                        Classes="mono"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#433829"
                        Text="88.5%" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
